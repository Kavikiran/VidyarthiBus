<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <!-- Back Button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:paddingEnd="12dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Crowd Status"
            android:textColor="@color/text_white"
            android:textSize="20sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Route Name -->
    <TextView
        android:id="@+id/tvRouteName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="Route Name"
        android:textColor="@color/text_primary"
        android:textSize="18sp"
        android:textStyle="bold"/>

    <!-- Crowd Status Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardCrowdStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvRouteName"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:cardBackgroundColor="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Status Label -->
            <TextView
                android:id="@+id/tvStatusLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Current Status"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <!-- Status Text -->
            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Loading..."
                android:textColor="@color/crowd_empty"
                android:textSize="36sp"
                android:textStyle="bold"/>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/crowdProgressBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"
                android:layout_marginTop="16dp"
                android:progress="0"
                android:max="100"
                android:progressTint="@color/crowd_empty"
                android:progressBackgroundTint="@color/divider"/>

            <!-- Progress Label -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Empty"
                    android:textColor="@color/crowd_empty"
                    android:textSize="12sp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Full"
                    android:textColor="@color/crowd_full"
                    android:textSize="12sp"/>

            </LinearLayout>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="16dp"
                android:background="@color/divider"/>

            <!-- Reporter Info -->
            <TextView
                android:id="@+id/tvReporterInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/no_reports_yet"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

            <!-- Time Info -->
            <TextView
                android:id="@+id/tvTimeInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="13sp"/>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardCrowdStatus"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:visibility="visible"/>

    <!-- Alternatives Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAlternatives"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="32dp"
        android:text="View Shared Auto Alternatives"
        android:textAllCaps="false"
        android:textSize="15sp"
        app:backgroundTint="@color/primary"
        app:cornerRadius="12dp"/>

</RelativeLayout>