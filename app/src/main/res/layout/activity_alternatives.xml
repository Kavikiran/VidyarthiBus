<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/primary"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">

        <!-- Back Button -->
        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="‹"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:paddingEnd="12dp"/>

        <!-- Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shared Auto Alternatives"
            android:textColor="@color/text_white"
            android:textSize="20sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- Info Message -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/topBar"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/primary_light">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="🚗 The bus is full! Here are local Shared Auto contacts near your route."
            android:textColor="@color/white"
            android:textSize="14sp"/>

    </androidx.cardview.widget.CardView>

    <!-- Loading indicator -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardInfo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:visibility="visible"/>

    <!-- No contacts message -->
    <TextView
        android:id="@+id/tvNoContacts"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/cardInfo"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"
        android:text="@string/no_auto_contacts"
        android:textColor="@color/text_secondary"
        android:textSize="16sp"
        android:gravity="center"
        android:visibility="gone"/>

    <!-- Auto Contacts List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewAutos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/cardInfo"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:clipToPadding="false"
        android:visibility="gone"/>

</RelativeLayout>